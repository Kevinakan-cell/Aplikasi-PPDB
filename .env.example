# Supabase Configuration
# Temukan URL dan Anon Key di: Dashboard Supabase -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (Hanya untuk digunakan di Server-side admin/webhook, jangan ekspos ke client)
# Temukan Service Role Key di: Dashboard Supabase -> Project Settings -> API -> service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Konfigurasi Midtrans Payment Gateway
# Temukan Server/Client Key di: Dashboard Midtrans -> Settings -> Access Keys
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
